# ============================================================
# Qorstack Report - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Admin Account (created on first startup, only when database is empty) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=YourStrongPassword123!

# --- Database (PostgreSQL) ---
DB_HOST=qorstack-postgres
DB_PORT=5432
DB_NAME=qorstack_report
DB_USER=postgres
DB_PASSWORD=your-strong-password-here

# --- MinIO (Object Storage) ---
MINIO_ENDPOINT=qorstack-minio:9000
MINIO_PUBLIC_ENDPOINT=https://minio.your-domain.com
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your-minio-secret-here
MINIO_BUCKET_TEMPLATE=templates
MINIO_BUCKET_REPORT=reports
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Gotenberg (PDF Engine) ---
GOTENBERG_URL=http://qorstack-gotenberg:3000
GOTENBERG_PORT=3000

# --- JWT (Change these for production!) ---
# Key must be at least 32 characters
JWT_KEY=your-256-bit-secret-key-must-be-at-least-32-chars
JWT_ISSUER=qorstack-report
JWT_AUDIENCE=qorstack-report-client

# --- Encryption (Required for sensitive data) ---
# Key must be exactly 32 characters (256-bit)
ENCRYPTION_KEY=your-32-char-encryption-key-here!!
# IV must be exactly 16 characters (128-bit)
ENCRYPTION_IV=your-16-char-iv!!

# --- API ---
ASPNETCORE_ENVIRONMENT=Production
API_PORT=8080

# --- Frontend (Next.js) ---
FRONTEND_PORT=3000
NEXT_PUBLIC_BRAND_DOMAIN=your-domain.com
NEXT_PUBLIC_BRAND_URL=https://your-domain.com
NEXT_PUBLIC_SERVICE=https://api.your-domain.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- CORS ---
# Comma separated list of allowed origins
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# --- Nginx UI ---
NGINX_UI_PORT=8090
