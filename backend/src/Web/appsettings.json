{
  "AllowedHosts": "*",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore.SpaProxy": "Warning",
      "Microsoft.Hosting.Lifetime": "None"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Database": {
    "MigrationPaths": [ "database" ]
  },
  "Minio": {
    "Endpoint": "",
    "PublicEndpoint": "",
    "AccessKey": "",
    "SecretKey": "",
    "UseSsl": false,
    "TemplateBucket": "",
    "ReportBucket": ""
  },
  "Gotenberg": {
    "BaseUrl": "",
    "TimeoutSeconds": 60
  },
  "QorstackReport": {
    "TempFileExpiryMinutes": 60,
    "MaxFileSizeMb": 50,
    "AllowedExtensions": [".docx"],
    "PreInstalledFonts": [
      "TH Sarabun New",
      "THSarabunNew",
      "Angsana New",
      "AngsanaUPC",
      "Cordia New",
      "CordiaUPC",
      "Browallia New",
      "BrowalliaUPC"
    ]
  },
  "DocumentProcessing": {
    "EnableXmlDownload": false,
    "XmlDownloadPath": "D:\\QorstackReport\\debug_xml",
    "EnableImageOptimization": true
  },
  "Jwt": {
    "Issuer": "",
    "Audience": "",
    "Key": "",
    "ExpiryMinutes": 60
  },
  "Encryption": {
    "Key": "",
    "IV": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3030",
      "http://127.0.0.1:3000",
      "http://127.0.0.1:3030"
    ]
  }
}
